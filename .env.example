# Daily Beltway — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# =============================================================================
# Dropbox Integration
# =============================================================================

# Dropbox API OAuth2 access token
# Get this from: https://www.dropbox.com/developers/apps
# Create an App → Generate access token → paste here
DROPBOX_ACCESS_TOKEN=

# Dropbox destination folder for rendered packages
# The folder will be created if it doesn't exist
DROPBOX_DEST_PATH=/Daily Beltway/READY_TO_REVIEW

# =============================================================================
# Local Paths (optional overrides)
# =============================================================================

# Absolute path to local output directory
# Default: output/ relative to project root
LOCAL_OUTPUT_PATH=

# Absolute path to ffmpeg binary
# Default: auto-detected from PATH / /opt/homebrew/bin / /usr/local/bin / /usr/bin
FFMPEG_BIN=

# =============================================================================
# Future: Claude API Integration (for headline generation)
# =============================================================================

# ANTHROPIC_API_KEY=
